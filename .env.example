# Site URL (used for SEO metadata and sitemaps)
NEXT_PUBLIC_SITE_URL=https://cleanify.app

# Optional: Weather API key for the weather plugin
# Get one free at https://openweathermap.org/api
NEXT_PUBLIC_WEATHER_API_KEY=

# Optional: Analytics
